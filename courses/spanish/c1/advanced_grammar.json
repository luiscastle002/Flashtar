  "cards": [
    {
      "id": "64d9d4e2-8e3d-484d-8f4d-84a2b3d705ef",
      "front": "<div class=\"text-6xl font-bold text-center\">Hubiera sabido</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>If I had known</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">hu-bie-ra sa-bi-do</div>",
      "position": 0
    },
    {
      "id": "204f487d-bc22-49f7-8b62-feb754172751",
      "front": "<div class=\"text-6xl font-bold text-center\">Fuere como fuere</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Be that as it may</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">fue-re co-mo fue-re</div>",
      "position": 1
    },
    {
      "id": "64492bd1-62e1-4d9d-84a8-bef3ac7245cc",
      "front": "<div class=\"text-6xl font-bold text-center\">Por más que intente</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>However much I try</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">por más que in-ten-te</div>",
      "position": 2
    },
    {
      "id": "fe5f56da-dd66-4496-8b1f-05d16b4062c7",
      "front": "<div class=\"text-6xl font-bold text-center\">A no ser que</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Unless</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">a no ser que</div>",
      "position": 3
    },
    {
      "id": "74ece55f-f924-4e63-92cd-aecf2e72831a",
      "front": "<div class=\"text-6xl font-bold text-center\">Tan pronto como</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>As soon as</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">tan pro-nto co-mo</div>",
      "position": 4
    },
    {
      "id": "9b297f5f-aafa-4e21-af87-7524dee8f6b4",
      "front": "<div class=\"text-6xl font-bold text-center\">Haya sido quien haya sido</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Whoever it may have been</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">ha-ya si-do quien ha-ya si-do</div>",
      "position": 5
    },
    {
      "id": "6694fc0f-9cb8-442d-8619-9d6d7192fcb1",
      "front": "<div class=\"text-6xl font-bold text-center\">De ahí que</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Hence / That is why</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">de ahí que</div>",
      "position": 6
    },
    {
      "id": "710988cc-3827-474c-be20-43a13bb83db1",
      "front": "<div class=\"text-6xl font-bold text-center\">En cuanto lo sepa</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>As soon as I know it</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">en cuan-to lo se-pa</div>",
      "position": 7
    },
    {
      "id": "acfc7971-a643-4fa3-9e11-f99dab53375f",
      "front": "<div class=\"text-6xl font-bold text-center\">Dondequiera que vayas</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Wherever you go</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">don-de-quie-ra que va-yas</div>",
      "position": 8
    },
    {
      "id": "8c66da17-795f-4367-a972-852db55aa479",
      "front": "<div class=\"text-6xl font-bold text-center\">Quienquiera que sea</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Whoever it may be</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">quien-quie-ra que se-a</div>",
      "position": 9
    },
    {
      "id": "1b8417d2-980b-4ddc-a140-63210722bff6",
      "front": "<div class=\"text-6xl font-bold text-center\">Si tuviera dinero</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>If I had money</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">si tu-vie-ra di-ne-ro</div>",
      "position": 10
    },
    {
      "id": "5b28c3ee-a2ec-4431-887a-4d161a594b8b",
      "front": "<div class=\"text-6xl font-bold text-center\">Como si fuera verdad</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>As if it were true</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">co-mo si fue-ra ver-dad</div>",
      "position": 11
    },
    {
      "id": "1f691bcf-3593-4810-9c68-306df6704896",
      "front": "<div class=\"text-6xl font-bold text-center\">Ojalá hubieras venido</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>I wish you had come</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">o-ja-lá hu-bie-ras ve-ni-do</div>",
      "position": 12
    },
    {
      "id": "e3271fe1-3582-4486-ac48-630ebc8e7c81",
      "front": "<div class=\"text-6xl font-bold text-center\">Aunque llueva</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Even if it rains</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">aun-que llu-e-va</div>",
      "position": 13
    },
    {
      "id": "0d5a7fef-d527-4ad8-b321-00c6e143c0e9",
      "front": "<div class=\"text-6xl font-bold text-center\">Si hubieras dicho</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>If you had said</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">si hu-bie-ras di-cho</div>",
      "position": 14
    },
    {
      "id": "da6a70ea-65d0-471b-884a-becffefc5b4d",
      "front": "<div class=\"text-6xl font-bold text-center\">De modo que</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>So that / In such a way that</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">de mo-do que</div>",
      "position": 15
    },
    {
      "id": "f4fdd263-ea7e-4ca7-a884-d519a3054f33",
      "front": "<div class=\"text-6xl font-bold text-center\">Sin que me vea</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Without him seeing me</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">sin que me ve-a</div>",
      "position": 16
    },
    {
      "id": "4dc883ed-47cb-4ae8-b46f-9a53771def93",
      "front": "<div class=\"text-6xl font-bold text-center\">A menos que vengas</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Unless you come</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">a me-nos que ven-gas</div>",
      "position": 17
    },
    {
      "id": "467ae3a5-b3a7-4c16-b484-8616bf345c36",
      "front": "<div class=\"text-6xl font-bold text-center\">Hasta que sea tarde</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Until it is late</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">has-ta que se-a tar-de</div>",
      "position": 18
    },
    {
      "id": "ff3fdf2d-5bb2-40ea-8f3f-ee97bbbef802",
      "front": "<div class=\"text-6xl font-bold text-center\">Antes de que salgas</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Before you leave</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">an-tes de que sal-gas</div>",
      "position": 19
    },
    {
      "id": "ce39dcc4-1171-4e1f-bc9a-65a4def6ccdf",
      "front": "<div class=\"text-6xl font-bold text-center\">Aunque sepa la verdad</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Even if he knows the truth</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">aun-que se-pa la ver-dad</div>",
      "position": 20
    },
    {
      "id": "79722381-64e7-4aa8-818a-c7f09a294175",
      "front": "<div class=\"text-6xl font-bold text-center\">Para que entiendas</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>So that you understand</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">pa-ra que en-tien-das</div>",
      "position": 21
    },
    {
      "id": "c404bc4f-c7ff-4dc3-b60d-3ed739058748",
      "front": "<div class=\"text-6xl font-bold text-center\">Después de que llegues</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>After you arrive</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">des-pués de que lle-gues</div>",
      "position": 22
    },
    {
      "id": "bec1eff2-cbcf-4cef-aec4-d419b2f39d64",
      "front": "<div class=\"text-6xl font-bold text-center\">Mientras sea posible</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>As long as it is possible</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">mien-tras se-a po-si-ble</div>",
      "position": 23
    },
    {
      "id": "cd776939-5df9-41a1-9aaa-7b91482531de",
      "front": "<div class=\"text-6xl font-bold text-center\">A pesar de que digas</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Despite the fact that you say</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">a pe-sar de que di-gas</div>",
      "position": 24
    },
    {
      "id": "cf159c38-4610-4671-a2e6-ea0012c8a7f9",
      "front": "<div class=\"text-6xl font-bold text-center\">Con tal de que vengas</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Provided that you come</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">con tal de que ven-gas</div>",
      "position": 25
    },
    {
      "id": "6477e41b-d8e2-40d4-9eeb-b60270172fde",
      "front": "<div class=\"text-6xl font-bold text-center\">Sea lo que sea</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>Whatever it may be</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">se-a lo que se-a</div>",
      "position": 26
    },
    {
      "id": "3ced301d-031f-4088-aef8-679f4e4610ed",
      "front": "<div class=\"text-6xl font-bold text-center\">Por mucho que corra</div>",
      "back": "<div class=\"text-4xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>No matter how much I run</div><div class=\"text-2xl text-center text-muted-foreground mt-2\">por mu-cho que co-rra</div>",
      "position": 27
    }
  ]
}