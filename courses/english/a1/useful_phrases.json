      "front": "<div class=\"text-5xl font-bold text-center\">How much is this?</div>",
      "back": "<div class=\"text-3xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>A phrase used to ask about the price of an item.</div>",
      "position": 1
    },
    {
      "id": "b0000000-0000-0000-0000-000000000050",
      "front": "<div class=\"text-5xl font-bold text-center\">Where is the bathroom?</div>",
      "back": "<div class=\"text-3xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>A phrase used to ask for the location of the toilet.</div>",
      "position": 2
    },
    {
      "id": "b0000000-0000-0000-0000-000000000051",
      "front": "<div class=\"text-5xl font-bold text-center\">I don't understand</div>",
      "back": "<div class=\"text-3xl text-center\"><span class=\"text-muted-foreground text-lg block\">Meaning</span>A phrase used when you do not comprehend what someone said.</div>",
      "position": 3
    },
    {
